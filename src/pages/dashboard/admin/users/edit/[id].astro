---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import UserForm from '@/components/dashboard/UserForm';
import { prisma } from '@/lib/prisma';

const { user } = Astro.locals;
const { id } = Astro.params;

if (user?.role !== 'ADMIN') {
  return Astro.redirect('/dashboard');
}

const targetUser = await prisma.user.findUnique({
  where: { id }
});

if (!targetUser) {
  return Astro.redirect('/dashboard/admin/users');
}
---

<DashboardLayout title="Edit Pegawai">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <a href="/dashboard/admin/users" class="text-sm text-indigo-600 hover:underline flex items-center gap-1">
        ← Kembali ke Daftar Pegawai
      </a>
      <h1 class="text-2xl font-bold text-slate-900 mt-2 italic">Edit Data Pegawai</h1>
      <p class="text-slate-500">Ubah informasi akun pegawai di bawah ini.</p>
    </div>
    <UserForm client:load initialData={targetUser} isEdit />
  </div>
</DashboardLayout>
