---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import ProductForm from '@/components/dashboard/ProductForm';

const { user } = Astro.locals;

if (user?.role !== 'ADMIN' && user?.role !== 'MANAGER') {
  return Astro.redirect('/dashboard');
}
---

<DashboardLayout title="Tambah Produk">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <a href="/dashboard/products" class="text-sm text-indigo-600 hover:underline flex items-center gap-1">
        ← Kembali ke Daftar Produk
      </a>
      <h1 class="text-2xl font-bold text-slate-900 mt-2 italic">Tambah Produk Baru</h1>
      <p class="text-slate-500">Silakan isi data produk di bawah ini.</p>
    </div>
    <ProductForm client:load />
  </div>
</DashboardLayout>
