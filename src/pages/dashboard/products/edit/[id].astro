---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import ProductForm from '@/components/dashboard/ProductForm';
import { prisma } from '@/lib/prisma';

const { user } = Astro.locals;
const { id } = Astro.params;

if (user?.role !== 'ADMIN' && user?.role !== 'MANAGER') {
  return Astro.redirect('/dashboard');
}

const product = await prisma.product.findUnique({
  where: { 
    id,
    storeId: user.storeId!
  }
});

if (!product) {
  return Astro.redirect('/dashboard/products');
}

const formattedProduct = {
  ...product,
  expiryDate: product.expiryDate ? product.expiryDate.toISOString() : null,
  createdAt: product.createdAt.toISOString(),
  updatedAt: product.updatedAt.toISOString()
};
---

<DashboardLayout title="Edit Produk">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <a href="/dashboard/products" class="text-sm text-indigo-600 hover:underline flex items-center gap-1">
        ← Kembali ke Daftar Produk
      </a>
      <h1 class="text-2xl font-bold text-slate-900 mt-2 italic">Edit Data Produk</h1>
      <p class="text-slate-500">Ubah informasi produk di bawah ini.</p>
    </div>
    <ProductForm client:load initialData={formattedProduct as any} isEdit />
  </div>
</DashboardLayout>
