---
import Layout from '../layouts/Layout.astro';
import { Rocket, Users, Gift, BarChart3 } from 'lucide-react';
import PublicNavbar from '../components/PublicNavbar.astro';

const { user } = Astro.locals;
---

<Layout title="Selamat Datang">
  <main>
    <PublicNavbar user={user} />

    <section class="min-h-screen flex items-center justify-center pt-24 px-4 relative overflow-hidden bg-slate-50">
      <div class="absolute top-[-20%] left-[-10%] w-[40rem] h-[40rem] bg-blue-100 rounded-full mix-blend-multiply filter blur-[120px] opacity-30 animate-pulse"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[35rem] h-[35rem] bg-blue-100 rounded-full mix-blend-multiply filter blur-[100px] opacity-30"></div>
      
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <div class="inline-block px-4 py-2 bg-blue-50 text-blue-600 rounded-full text-[10px] uppercase font-bold tracking-[0.3em] mb-8 animate-bounce">
          Solusi POS UMKM Modern
        </div>
        <h1 class="text-5xl md:text-7xl font-bold text-slate-900 tracking-tighter mb-8">
          Ekosistem Toko <br /> <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-violet-600">Cerdas & Dinamis</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-500 mb-12 max-w-2xl mx-auto leading-relaxed font-medium">
          Transformasi operasional bisnis Anda dengan integrasi stok real-time, manajemen tim terenkripsi, dan analitik performa dalam satu sentuhan.
        </p>
        <div class="flex flex-col sm:flex-row gap-5 justify-center">
          <a href="/auth/register" class="px-10 py-5 bg-blue-600 text-white rounded-2xl font-bold text-lg hover:bg-blue-700 hover:-translate-y-1 transition-all duration-300 shadow-2xl shadow-blue-100">
            Daftar Eksklusif
          </a>
          <a href="#features" class="px-10 py-5 bg-white text-slate-500 border border-slate-200 rounded-2xl font-bold text-lg hover:bg-slate-50 hover:-translate-y-1 transition-all duration-300 shadow-sm">
            Eksplorasi Fitur
          </a>
        </div>
      </div>
    </section>

    <section id="features" class="py-32 bg-white scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-24">
          <p class="text-blue-600 font-black uppercase tracking-[.4em] text-[10px] mb-4">Functional Excellence</p>
          <h2 class="text-5xl font-black text-slate-900 tracking-tight">Ecosystem Kasir Modern</h2>
          <p class="text-slate-400 font-medium mt-4 max-w-xl mx-auto">Kami memberikan kontrol total atas inventaris Anda, dari gudang hingga rak jualan.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          <div class="bg-slate-50/50 p-12 rounded-[3.5rem] border border-slate-100 hover:border-blue-600 hover:bg-white transition-all duration-500 group relative overflow-hidden">
            <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
                <Rocket className="w-24 h-24 text-blue-600" />
            </div>
            <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-10 shadow-sm group-hover:scale-110 group-hover:bg-blue-600 group-hover:rotate-6 transition-all duration-500">
              <Rocket className="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" />
            </div>
            <h3 class="text-2xl font-black mb-4 text-slate-900">Hybrid Logistics</h3>
            <p class="text-slate-500 text-sm leading-relaxed font-bold uppercase tracking-tight">Manajemen stok ganda: Pisahkan stok gudang (backroom) dan stok rak (showcase) untuk akurasi display 100%.</p>
          </div>

          <div class="bg-slate-50/50 p-12 rounded-[3.5rem] border border-slate-100 hover:border-blue-600 hover:bg-white transition-all duration-500 group relative overflow-hidden">
             <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
                <Users className="w-24 h-24 text-blue-600" />
            </div>
            <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-10 shadow-sm group-hover:scale-110 group-hover:bg-blue-600 group-hover:-rotate-6 transition-all duration-500">
              <Users className="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" />
            </div>
            <h3 class="text-2xl font-black mb-4 text-slate-900">Multi-Role Access</h3>
            <p class="text-slate-500 text-sm leading-relaxed font-bold uppercase tracking-tight">Keamanan data terjamin. Batasi akses staf gudang, kasir, dan manajer sesuai dengan tanggung jawab masing-masing.</p>
          </div>

          <div class="bg-slate-50/50 p-12 rounded-[3.5rem] border border-slate-100 hover:border-emerald-600 hover:bg-white transition-all duration-500 group relative overflow-hidden">
             <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
                <BarChart3 className="w-24 h-24 text-emerald-600" />
            </div>
            <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-10 shadow-sm group-hover:scale-110 group-hover:bg-emerald-600 group-hover:rotate-12 transition-all duration-500">
              <BarChart3 className="w-8 h-8 text-emerald-600 group-hover:text-white transition-colors" />
            </div>
            <h3 class="text-2xl font-black mb-4 text-slate-900">Real-Time Insight</h3>
            <p class="text-slate-500 text-sm leading-relaxed font-bold uppercase tracking-tight">Pantau pergerakan omzet dan sisa stok secara instan melalui dashboard yang intuitif dan responsif.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-5xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-16 text-slate-900">3 Langkah Mudah Memulai</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div class="relative group">
            <div class="w-20 h-20 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-3xl font-bold mx-auto mb-8 shadow-lg shadow-blue-200 group-hover:-translate-y-2 transition-all duration-300">1</div>
            <h4 class="text-xl font-bold mb-3 text-slate-900">Buat Toko</h4>
            <p class="text-slate-600">Daftarkan akun Admin dan masukkan profil toko Anda.</p>
          </div>
          <div class="relative group">
            <div class="w-20 h-20 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-3xl font-bold mx-auto mb-8 shadow-lg shadow-blue-200 group-hover:-translate-y-2 transition-all duration-300">2</div>
            <h4 class="text-xl font-bold mb-3 text-slate-900">Tambah Produk</h4>
            <p class="text-slate-600">Masukkan daftar produk dan atur stok awal Anda.</p>
          </div>
          <div class="relative group">
            <div class="w-20 h-20 bg-blue-600 text-white rounded-2xl flex items-center justify-center text-3xl font-bold mx-auto mb-8 shadow-lg shadow-blue-200 group-hover:-translate-y-2 transition-all duration-300">3</div>
            <h4 class="text-xl font-bold mb-3 text-slate-900">Mulai Transaksi</h4>
            <p class="text-slate-600">Buka halaman kasir dan layani pelanggan pertama Anda!</p>
          </div>
        </div>
      </div>
    </section>

    <footer class="bg-slate-50 border-t border-slate-200 py-20">
      <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-12">
        <div class="flex flex-col items-center md:items-start text-center md:text-left">
          <div class="flex items-center gap-3 mb-6">
            <span class="font-bold text-xl tracking-tight text-slate-900">Kasir<span class="animate-moving-gradient">Ku</span></span>
          </div>
          <p class="text-slate-400 text-xs font-medium uppercase tracking-[0.2em]">© 2026 KasirKu UMKM. All Rights Reserved.</p>
        </div>
        <div class="flex flex-wrap justify-center gap-10 text-xs font-medium text-slate-400 uppercase tracking-widest">
          <a href="#" class="hover:text-blue-600 transition-colors">Digital Privacy</a>
          <a href="#" class="hover:text-blue-600 transition-colors">Legal Terms</a>
          <a href="#" class="hover:text-blue-600 transition-colors">Global Support</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style is:global>
  /* Menambahkan efek scroll meluncur perlahan */
  html {
    scroll-behavior: smooth;
  }
</style>
